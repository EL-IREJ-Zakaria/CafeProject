RewriteEngine On

RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

RewriteRule ^api/?$ backend/api/index.php [QSA,L]
RewriteRule ^api/(.*)$ backend/api/index.php [QSA,L]
RewriteRule ^table/([0-9]+)/?$ frontend/index.html [QSA,L]
RewriteRule ^$ frontend/index.html [L]
